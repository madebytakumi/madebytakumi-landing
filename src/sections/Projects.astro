---
import { Sparkles } from "@lucide/astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import { getProjects } from "@/data/projects";
import { es } from "@/i18n/es";

const projects = getProjects("es");
---

<section id="projects" class="border-y hairline bg-surface/35 py-24 sm:py-32">
  <div class="container-shell">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
      <SectionTitle eyebrowKey="projects.eyebrow" titleKey="projects.title" eyebrow={es.projects.eyebrow} title={es.projects.title} />
      <p class="reveal max-w-xl text-base leading-8 text-muted lg:justify-self-end">
        <span data-i18n="projects.intro">{es.projects.intro}</span>
      </p>
    </div>
    <div class="mt-14 grid gap-5 lg:grid-cols-3">
      {projects.map((project, index) => <ProjectCard project={project} index={index} />)}
      <article class="reveal flex flex-col rounded-[calc(var(--radius)*1.35)] border border-dashed hairline bg-surface/30 p-6 opacity-60 sm:p-8">
        <div class="mb-10 flex items-start justify-between gap-6">
          <span class="grid size-12 place-items-center rounded-xl border border-dashed hairline text-muted">
            <Sparkles class="size-5" stroke-width={1.6} aria-hidden="true" />
          </span>
          <span class="h-12 w-px origin-top bg-line"></span>
        </div>
        <h3 class="text-2xl font-semibold tracking-[-0.03em] text-muted" data-i18n="projects.soon">{es.projects.soon}</h3>
        <p class="mt-4 text-base leading-7 text-muted" data-i18n="projects.soonNote">{es.projects.soonNote}</p>
      </article>
    </div>
  </div>
</section>
